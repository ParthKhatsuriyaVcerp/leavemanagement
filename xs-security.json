{
  "xsappname": "leave-management",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Employee",
      "description": "Can submit leave requests"
    },
    {
      "name": "$XSAPPNAME.Manager",
      "description": "Level 1 — Direct manager approval"
    },
    {
      "name": "$XSAPPNAME.TeamLead",
      "description": "Level 2 — Team lead approval"
    },
    {
      "name": "$XSAPPNAME.ProjectManager",
      "description": "Level 3 — Project manager approval"
    },
    {
      "name": "$XSAPPNAME.HR",
      "description": "Level 4 — HR final approval"
    },
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Full admin access"
    }
  ],
  "role-templates": [
    {
      "name"             : "Employee",
      "description"      : "Regular employee",
      "scope-references" : ["$XSAPPNAME.Employee"]
    },
    {
      "name"             : "Manager",
      "description"      : "Direct manager",
      "scope-references" : ["$XSAPPNAME.Manager", "$XSAPPNAME.Employee"]
    },
    {
      "name"             : "TeamLead",
      "description"      : "Team lead",
      "scope-references" : ["$XSAPPNAME.TeamLead", "$XSAPPNAME.Manager", "$XSAPPNAME.Employee"]
    },
    {
      "name"             : "ProjectManager",
      "description"      : "Project manager",
      "scope-references" : ["$XSAPPNAME.ProjectManager", "$XSAPPNAME.TeamLead", "$XSAPPNAME.Manager", "$XSAPPNAME.Employee"]
    },
    {
      "name"             : "HR",
      "description"      : "HR department",
      "scope-references" : ["$XSAPPNAME.HR", "$XSAPPNAME.Employee"]
    },
    {
      "name"             : "Admin",
      "description"      : "Administrator",
      "scope-references" : ["$XSAPPNAME.Admin", "$XSAPPNAME.HR", "$XSAPPNAME.ProjectManager", "$XSAPPNAME.TeamLead", "$XSAPPNAME.Manager", "$XSAPPNAME.Employee"]
    }
  ],
  "role-collections": [
    {
      "name"                    : "LeaveApp-Employee",
      "description"             : "Employee role collection",
      "role-template-references": ["$XSAPPNAME.Employee"]
    },
    {
      "name"                    : "LeaveApp-Manager",
      "description"             : "Manager role collection",
      "role-template-references": ["$XSAPPNAME.Manager"]
    },
    {
      "name"                    : "LeaveApp-TeamLead",
      "description"             : "Team Lead role collection",
      "role-template-references": ["$XSAPPNAME.TeamLead"]
    },
    {
      "name"                    : "LeaveApp-ProjectManager",
      "description"             : "Project Manager role collection",
      "role-template-references": ["$XSAPPNAME.ProjectManager"]
    },
    {
      "name"                    : "LeaveApp-HR",
      "description"             : "HR role collection",
      "role-template-references": ["$XSAPPNAME.HR"]
    }
  ]
}