  "definitions": {
    "com.leaveapp.Users": {
      "kind": "entity",
      "includes": [
        "cuid",
        "managed"
      ],
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "createdAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "createdBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@Core.Immutable": true,
          "@title": "{i18n>CreatedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "modifiedAt": {
          "@cds.on.insert": {
            "=": "$now"
          },
          "@cds.on.update": {
            "=": "$now"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedAt}",
          "@readonly": true,
          "type": "cds.Timestamp"
        },
        "modifiedBy": {
          "@cds.on.insert": {
            "=": "$user"
          },
          "@cds.on.update": {
            "=": "$user"
          },
          "@UI.HiddenFilter": true,
          "@UI.ExcludeFromNavigationContext": true,
          "@title": "{i18n>ChangedBy}",
          "@readonly": true,
          "@description": "{i18n>UserID.Description}",
          "type": "User",
          "length": 255
        },
        "email": {
          "type": "cds.String",
          "length": 100,
          "notNull": true
        },
        "passwordHash": {
          "type": "cds.String",
          "length": 256,
          "notNull": true
        },
        "firstName": {
          "type": "cds.String",
          "length": 50,
          "notNull": true
        },
        "lastName": {
          "type": "cds.String",
          "length": 50,
          "notNull": true
        },
        "roleCode": {
          "type": "cds.String",
          "length": 20,
          "notNull": true,
          "default": {
            "val": "EMPLOYEE"
          }
        },
        "approvalLevel": {
          "type": "cds.Integer",
          "notNull": true,
          "default": {
            "val": 0
          }
        },
        "manager": {
          "type": "cds.Association",
          "target": "com.leaveapp.Users",
          "keys": [
            {
              "ref": [
                "ID"
              ]
            }
          ]
        },
        "department": {
          "type": "cds.String",
          "length": 100
        },
        "isActive": {
          "type": "cds.Boolean",
          "default": {
            "val": true
          }
        }
      }
    },
