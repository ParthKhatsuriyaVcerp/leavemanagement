    "com.leaveapp.EmployeeHierarchyView": {
      "kind": "entity",
      "query": {
        "SELECT": {
          "from": {
            "ref": [
              "com.leaveapp.Users"
            ],
            "as": "emp"
          },
          "columns": [
            {
              "ref": [
                "emp",
                "ID"
              ]
            },
            {
              "ref": [
                "emp",
                "firstName"
              ]
            },
            {
              "ref": [
                "emp",
                "lastName"
              ]
            },
            {
              "ref": [
                "emp",
                "email"
              ]
            },
            {
              "ref": [
                "emp",
                "roleCode"
              ]
            },
            {
              "ref": [
                "emp",
                "department"
              ]
            },
            {
              "ref": [
                "emp",
                "manager",
                "firstName"
              ],
              "as": "managerFirstName"
            },
            {
              "ref": [
                "emp",
                "manager",
                "lastName"
              ],
              "as": "managerLastName"
            },
            {
              "ref": [
                "emp",
                "manager",
                "email"
              ],
              "as": "managerEmail"
            }
          ],
          "where": [
            {
              "ref": [
                "emp",
                "isActive"
              ]
            },
            "=",
            {
              "val": true
            }
          ]
        }
      },
      "elements": {
        "ID": {
          "key": true,
          "type": "cds.UUID"
        },
        "firstName": {
          "type": "cds.String",
          "length": 50,
          "notNull": true
        },
        "lastName": {
          "type": "cds.String",
          "length": 50,
          "notNull": true
        },
        "email": {
          "type": "cds.String",
          "length": 100,
          "notNull": true
        },
        "roleCode": {
          "type": "cds.String",
          "length": 20,
          "notNull": true,
          "default": {
            "val": "EMPLOYEE"
          }
        },
        "department": {
          "type": "cds.String",
          "length": 100
        },
        "managerFirstName": {
          "type": "cds.String",
          "length": 50
        },
        "managerLastName": {
          "type": "cds.String",
          "length": 50
        },
        "managerEmail": {
          "type": "cds.String",
          "length": 100
        }
      }
    },
