{
  "name": "leave-management",
  "version": "1.0.0",
  "description": "Leave Management System with Multi-Level Approval Workflow",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@cap-js/hana": "^2.7.0",
    "@sap/cds": "^9",
    "@sap/xsenv": "^6.1.0",
    "@sap/xssec": "^4.13.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "npx cds build --production",
    "deploy:db": "npx hana-cli deploy --auto-undeploy"
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "dummy"
        }
      },
      "db": {
        "kind": "hana-cloud",
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "database": ":memory:"
          }
        }
      },
      "uaa": {
        "kind": "xsuaa"
      }
    },
    "server": {
      "cors": true
    },
    "build": {
      "target": "gen",
      "tasks": [
        {
          "for": "hana",
          "src": "db",
          "options": {
            "model": [
              "db",
              "srv"
            ]
          }
        },
        {
          "for": "nodejs",
          "src": "srv",
          "options": {
            "model": [
              "db",
              "srv"
            ]
          }
        }
      ]
    }
  }
}