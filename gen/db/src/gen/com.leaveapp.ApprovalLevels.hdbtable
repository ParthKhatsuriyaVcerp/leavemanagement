COLUMN TABLE com_leaveapp_ApprovalLevels (
  ID NVARCHAR(36) NOT NULL,
  department NVARCHAR(100) NOT NULL,
  totalLevels INTEGER NOT NULL DEFAULT 2,
  level1Role NVARCHAR(20) DEFAULT 'MANAGER',
  level2Role NVARCHAR(20) DEFAULT 'TEAMLEAD',
  level3Role NVARCHAR(20) DEFAULT 'PM',
  level4Role NVARCHAR(20) DEFAULT 'HR',
  PRIMARY KEY(ID)
)